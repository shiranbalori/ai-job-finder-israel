# Set true to use offline mock data only (no backend)

VITE_USE_MOCK=false



# Production — Render backend URL (no trailing slash). Required for Vercel builds.

# VITE_API_URL=https://your-backend.onrender.com



# Local dev — leave VITE_API_URL empty; Vite proxies to VITE_DEV_API_URL (see .env.development)

VITE_API_BASE_URL=


