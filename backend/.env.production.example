# Production template — copy values to Render/hosting env vars (NOT backend/.env for local dev).
# See docs/DEPLOYMENT.md for step-by-step Supabase setup.

APP_ENV=production

# Supabase transaction pooler (port 6543) — used by the running API
DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require

# Required with Supabase transaction pooler
DB_USE_NULL_POOL=true

# After setting env vars on Render (before first deploy):
#   python scripts/db_check.py
#   python scripts/db_init.py

# Optional: direct connection (port 5432) for Alembic if pooler migrations fail
# MIGRATION_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

JWT_SECRET=replace-with-long-random-string
CORS_ORIGINS=https://your-app.vercel.app
CORS_ORIGIN_REGEX=https://.*\.vercel\.app

AI_PROVIDER=mock
JOB_FETCH_ON_STARTUP=false

DAILY_EMAIL_ENABLED=false
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aijobfinder.co.il
