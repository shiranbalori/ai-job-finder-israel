# Copy to backend/.env for local development

APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# ── Local development (keep this) ─────────────────────────────────────────────
# SQLite — no Supabase account needed. Do NOT paste Supabase URLs here yet.
DATABASE_URL=sqlite:///./data/app.db

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_USE_NULL_POOL=false
# DB_RUN_MIGRATIONS_ON_STARTUP=false
# DB_MIGRATION_TIMEOUT_SEC=120

# ── Production (Render + Supabase) — paste on hosting, NOT in backend/.env ───
# APP_ENV=production blocks startup if DATABASE_URL is still SQLite.
# See backend/.env.production.example and docs/DEPLOYMENT.md
#
# APP_ENV=production
# DATABASE_URL=postgresql://postgres.[PROJECT-REF]:[PASSWORD]@aws-0-[REGION].pooler.supabase.com:6543/postgres?sslmode=require
# DB_USE_NULL_POOL=true
# MIGRATION_DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[PROJECT-REF].supabase.co:5432/postgres?sslmode=require
# JWT_SECRET=replace-with-long-random-string
# CORS_ORIGINS=https://your-app.vercel.app
# JOB_FETCH_ON_STARTUP=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

AI_PROVIDER=mock
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_EMBEDDING_MODEL=text-embedding-3-small
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
GEMINI_EMBEDDING_MODEL=text-embedding-004
USE_EMBEDDINGS=true

SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=noreply@aijobfinder.co.il
EMAIL_FROM=noreply@aijobfinder.co.il
SMTP_USE_TLS=true

DAILY_EMAIL_ENABLED=false
DAILY_EMAIL_HOUR=8
DAILY_EMAIL_RECIPIENT=demo@example.com

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080
DEMO_MODE_DEFAULT=false
MAX_UPLOAD_BYTES=10485760

GREENHOUSE_BOARD_TOKENS=
LEVER_COMPANY_SLUGS=
JOB_FETCH_ON_STARTUP=true
JOB_REFRESH_ENABLED=true
JOB_REFRESH_INTERVAL_HOURS=4
