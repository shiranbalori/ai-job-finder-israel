# Backend
APP_ENV=development
BACKEND_HOST=127.0.0.1
BACKEND_PORT=8000

# Local development — SQLite (no setup required)
DATABASE_URL=sqlite:///./data/app.db

# Production — Supabase PostgreSQL (see docs/DEPLOYMENT.md)
# APP_ENV=production
# DATABASE_URL=postgresql://postgres.[project-ref]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?sslmode=require
# DB_USE_NULL_POOL=true

DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10
DB_USE_NULL_POOL=false

CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
# Optional: allow Vercel preview deployments (production Render env)
# CORS_ORIGIN_REGEX=https://.*\.vercel\.app

# AI Provider: openai | gemini | mock
AI_PROVIDER=mock
OPENAI_API_KEY=your-openai-key-here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=your-gemini-key-here
GEMINI_MODEL=gemini-1.5-flash

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-password
SMTP_FROM=noreply@aijobfinder.co.il
EMAIL_FROM=noreply@aijobfinder.co.il
SMTP_USE_TLS=true

# Daily digest scheduler (master switch — user prefs in Settings UI)
DAILY_EMAIL_ENABLED=true
DAILY_EMAIL_HOUR=8
DAILY_EMAIL_RECIPIENT=demo@example.com

JWT_SECRET=change-me-in-production-use-long-random-string
JWT_EXPIRE_MINUTES=10080
DEMO_MODE_DEFAULT=false
MAX_UPLOAD_BYTES=10485760

# Job boards (comma-separated; empty = built-in defaults)
GREENHOUSE_BOARD_TOKENS=riskified,taboola,similarweb,jfrog,mondaydotcom,ai21labs,sentinelone,fireblocks
LEVER_COMPANY_SLUGS=walkme,gong,lemonade,wix,riskified
JOB_FETCH_ON_STARTUP=true
JOB_REFRESH_ENABLED=true
JOB_REFRESH_INTERVAL_HOURS=4
JOB_COLLECTOR_TIMEOUT_SEC=120

# Frontend (Vite)
# Production (Vercel): set to your Render backend URL
# VITE_API_URL=https://your-backend.onrender.com
# Local dev: leave empty — see frontend/.env.development for VITE_DEV_API_URL proxy target
VITE_API_URL=
VITE_USE_MOCK=false
